<%- include('partials/header') %>
<h2 class="mb-4 text-center" style="color:#6b3e1f;">🍰 Tất cả các loại bánh</h2>
<div class="row g-4">
  <% products.forEach(p => { %>
    <div class="col-md-4">
      <div class="card product-card">
        <img src="<%= p.imageUrl %>" class="card-img-top" alt="<%= p.name %>">
        <div class="card-body">
          <h5 class="card-title"><%= p.name %></h5>
          <p class="card-text"><%= p.description %></p>
          <div class="product-price"><%= p.price.toLocaleString() %>đ</div>
          <form method="post" action="/customer/add-to-cart" class="mt-3">
            <input type="hidden" name="productId" value="<%= p.id %>">
            <div class="row g-2">
              <div class="col-6">
                <input type="number" name="quantity" value="1" min="1" class="form-control" required>
              </div>
              <div class="col-6">
                <input type="date" name="deliveryDate" class="form-control" required>
              </div>
              <div class="col-12">
                <button type="submit" class="btn btn-buy w-100"><i class="bi bi-cart-plus"></i> Thêm vào giỏ</button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  <% }) %>
</div>
<%- include('partials/footer') %>