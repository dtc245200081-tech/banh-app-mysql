<%- include('partials/header') %>
<h2>📊 Báo cáo doanh thu</h2>

<div class="row">
  <div class="col-md-6">
    <div class="card text-white bg-primary mb-3">
      <div class="card-header">Tổng doanh thu</div>
      <div class="card-body">
        <h1 class="display-4"><%= totalRevenue.toLocaleString() %>đ</h1>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card text-white bg-info mb-3">
      <div class="card-header">Doanh thu theo sản phẩm</div>
      <div class="card-body">
        <table class="table table-sm text-white">
          <% for (const [name, revenue] of Object.entries(productRevenue)) { %>
            <tr><td><%= name %></td><td class="text-end"><%= revenue.toLocaleString() %>đ</td></tr>
          <% } %>
        </table>
      </div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>