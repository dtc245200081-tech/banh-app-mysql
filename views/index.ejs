<%- include('partials/header') %>

<div class="hero text-center">
  <h1><i class="aa"></i> Bánh ngon, giá tốt</h1>
  <p>Đặt bánh trực tuyến, thưởng thức cùng gia đình và bạn bè</p>
  <% if (!user) { %>
    <a href="/auth/register" class="btn btn-light btn-lg rounded-pill px-4">Đăng ký ngay <i class="bi bi-arrow-right"></i></a>
  <% } else if (user.role === 'customer') { %>
    <a href="/customer/products" class="btn btn-light btn-lg rounded-pill px-4">Đặt bánh ngay <i class="bi bi-cart-plus"></i></a>
  <% } %>
</div>

<h2 class="mb-4 text-center" style="color:#6b3e1f;">✨ Sản phẩm nổi bật ✨</h2>
<div class="row g-4">
  <% products.forEach(p => { %>
    <div class="col-md-4">
      <div class="card product-card">
        <img src="<%= p.imageUrl %>" class="card-img-top" alt="<%= p.name %>">
        <div class="card-body">
          <h5 class="card-title"><%= p.name %></h5>
          <p class="card-text text-muted"><%= p.description %></p>
          <div class="product-price"><%= p.price.toLocaleString() %>đ</div>
          <% if (user && user.role === 'customer') { %>
            <a href="/customer/products" class="btn btn-buy w-100">Đặt mua <i class="bi bi-cart-check"></i></a>
          <% } %>
        </div>
      </div>
    </div>
  <% }) %>
</div>

<%- include('partials/footer') %>
