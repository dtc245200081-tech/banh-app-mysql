<%- include('partials/header') %>
<h2><i class="bi bi-gear-fill"></i> Cài đặt hệ thống</h2>

<% if (typeof error !== 'undefined' && error) { %>
<div class="alert alert-danger alert-dismissible fade show" role="alert">
  <i class="bi bi-exclamation-triangle-fill"></i> <%= error %>
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
<% } %>

<div class="card">
  <div class="card-header bg-primary text-white">
    <i class="bi bi-cake"></i> Công suất sản xuất
  </div>
  <div class="card-body">
    <form method="post" action="/admin/settings">
      <div class="mb-3">
        <label class="form-label">Số lượng bánh tối đa mỗi ngày</label>
        <input type="number" name="capacity" class="form-control" value="<%= capacity %>" required min="1">
        <div class="form-text">Nhập số nguyên dương (ví dụ: 50).</div>
      </div>
      <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Lưu cài đặt</button>
    </form>
  </div>
</div>
<%- include('partials/footer') %>
